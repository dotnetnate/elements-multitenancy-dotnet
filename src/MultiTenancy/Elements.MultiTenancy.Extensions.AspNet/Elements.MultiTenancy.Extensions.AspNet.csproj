<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>MyOrg.Elements.MultiTenancy.AspNet</RootNamespace>
    <Description>ASP.NET Core integration for Elements multi-tenancy.</Description>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Elements.MultiTenancy\Elements.MultiTenancy.csproj" />
    <ProjectReference Include="..\..\..\..\elements-core-dotnet\src\Core\Elements.Core\Elements.Core.csproj" Condition="'$(ElementsCoreReferenceMode)' == 'Project'" />
    <ProjectReference Include="..\..\..\..\elements-core-dotnet\src\Security\Elements.Security.Authorization\Elements.Security.Authorization.csproj" Condition="'$(ElementsCoreReferenceMode)' == 'Project'" />
    <PackageReference Include="Elements.Core" Version="$(ElementsCorePackageVersion)" Condition="'$(ElementsCoreReferenceMode)' == 'Package'" />
    <PackageReference Include="Elements.Security.Authorization" Version="$(ElementsCorePackageVersion)" Condition="'$(ElementsCoreReferenceMode)' == 'Package'" />
  </ItemGroup>
</Project>
