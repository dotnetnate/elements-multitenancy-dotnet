<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    Auto-imported by NuGet when a consumer references this package.
    Copies the .github copilot content shipped under copilot/.github into the
    consumer's .github folder. Never overwrites existing files.

    The literal "TOKEN" in target and item names below is replaced at pack
    time with the safe (dot-free) package id so that multiple Elements.*
    packages can be referenced together without target-name or item
    collisions in the consumer.
  -->
  <Target Name="CopyCopilotGithubFiles___TOKEN__" AfterTargets="Build">
    <ItemGroup>
      <_CopilotSrc___TOKEN__
          Include="$(MSBuildThisFileDirectory)..\copilot\.github\**\*"
          Exclude="$(MSBuildThisFileDirectory)..\copilot\.github\**\.gitkeep" />
    </ItemGroup>
    <ItemGroup>
      <_CopilotNew___TOKEN__
          Include="@(_CopilotSrc___TOKEN__)"
          Condition="!Exists('$(MSBuildProjectDirectory)\.github\%(RecursiveDir)%(Filename)%(Extension)')" />
    </ItemGroup>
    <MakeDir Directories="$(MSBuildProjectDirectory)\.github\instructions;$(MSBuildProjectDirectory)\.github\skills;$(MSBuildProjectDirectory)\.github\agents;$(MSBuildProjectDirectory)\.github\prompts" />
    <Copy SourceFiles="@(_CopilotNew___TOKEN__)"
          DestinationFiles="@(_CopilotNew___TOKEN__->'$(MSBuildProjectDirectory)\.github\%(RecursiveDir)%(Filename)%(Extension)')"
          Condition="'@(_CopilotNew___TOKEN__)' != ''" />
  </Target>
</Project>
